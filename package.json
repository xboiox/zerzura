{
  "name": "next-js-boilerplate",
  "author": "Ixartz (https://github.com/ixartz)",
  "type": "module",
  "scripts": {
    "dev:spotlight": "npx @spotlightjs/spotlight",
    "dev:next": "next dev",
    "dev": "run-p db-server:file dev:*",
    "build:next": "next build",
    "build-local": "run-p db-server:memory build:next --race",
    "build": "run-s db:migrate build:next",
    "start": "next start",
    "build-stats": "cross-env ANALYZE=true npm run build",
    "clean": "rimraf .next out coverage",
    "lint": "ultracite check --type-aware --type-check",
    "lint:fix": "ultracite fix --type-aware --type-check",
    "check:types": "tsc --noEmit --pretty",
    "check:deps": "knip",
    "check:i18n": "i18n-check -l src/locales -s en -u src -f next-intl",
    "commit": "commit",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "db-server:file": "pglite-server -m 100 --db=local.db --run 'npm run db:migrate'",
    "db-server:memory": "pglite-server -m 100 --run 'npm run db:migrate'",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "dotenv -c -- drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "storybook": "storybook dev -p 6006",
    "storybook:test": "vitest run --config .storybook/vitest.config.ts",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@arcjet/next": "^1.4.0",
    "@clerk/localizations": "^4.6.8",
    "@clerk/nextjs": "^7.4.1",
    "@hookform/resolvers": "^5.2.2",
    "@logtape/logtape": "^2.1.1",
    "@sentry/nextjs": "^10.53.1",
    "@t3-oss/env-nextjs": "^0.13.11",
    "drizzle-orm": "^0.45.2",
    "next": "^16.2.6",
    "next-intl": "^4.12.0",
    "pg": "^8.21.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-hook-form": "^7.76.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@chromatic-com/playwright": "^0.14.2",
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@commitlint/prompt-cli": "^21.0.1",
    "@commitlint/types": "^21.0.1",
    "@electric-sql/pglite-socket": "^0.1.5",
    "@faker-js/faker": "^10.4.0",
    "@lingual/i18n-check": "^0.9.5",
    "@next/bundle-analyzer": "^16.2.6",
    "@playwright/test": "^1.60.0",
    "@spotlightjs/spotlight": "^4.11.4",
    "@storybook/addon-a11y": "^10.4.1",
    "@storybook/addon-docs": "^10.4.1",
    "@storybook/addon-vitest": "^10.4.1",
    "@storybook/nextjs-vite": "^10.4.1",
    "@swc/helpers": "^0.5.21",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^25.9.1",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.15",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/browser": "^4.1.7",
    "@vitest/browser-playwright": "^4.1.7",
    "@vitest/coverage-v8": "^4.1.7",
    "babel-plugin-react-compiler": "^1.0.0",
    "checkly": "^7.14.0",
    "cross-env": "^10.1.0",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.10",
    "knip": "^6.14.2",
    "lefthook": "^2.1.8",
    "npm-run-all": "^4.1.5",
    "oxfmt": "^0.51.0",
    "oxlint": "^1.66.0",
    "oxlint-tsgolint": "^0.23.0",
    "rimraf": "^6.1.3",
    "semantic-release": "^25.0.3",
    "storybook": "^10.4.1",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.9.3",
    "ultracite": "^7.7.0",
    "vitest": "^4.1.7",
    "vitest-browser-react": "^2.2.0"
  },
  "release": {
    "branches": [
      "main"
    ],
    "plugins": [
      [
        "@semantic-release/commit-analyzer",
        {
          "preset": "conventionalcommits"
        }
      ],
      "@semantic-release/release-notes-generator",
      "@semantic-release/github"
    ]
  },
  "engines": {
    "node": ">=24"
  },
  "postcss": {
    "plugins": {
      "@tailwindcss/postcss": {}
    }
  }
}
