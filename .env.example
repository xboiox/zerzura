# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Clerk Auth
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_WEBHOOK_SECRET=whsec_...

# Uploadthing (CV uploads)
UPLOADTHING_SECRET=sk_live_...
UPLOADTHING_APP_ID=...

# Resend (email notifications)
RESEND_API_KEY=re_...

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# Optional: Arcjet (rate limiting)
# ARCJET_KEY=ajkey_...

# Optional: Better Stack (logging)
# NEXT_PUBLIC_BETTER_STACK_SOURCE_TOKEN=...
# NEXT_PUBLIC_BETTER_STACK_INGESTING_HOST=...

# Optional: PostHog (analytics)
# NEXT_PUBLIC_POSTHOG_KEY=...
# NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Optional: logging level (error | info | debug | warning | trace | fatal)
# NEXT_PUBLIC_LOGGING_LEVEL=info
